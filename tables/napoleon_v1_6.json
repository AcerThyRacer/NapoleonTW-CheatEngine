{
    "game": "Napoleon Total War",
    "version": "1.6 (Steam)",
    "platform": ["windows", "linux"],
    "created": "2026-03-09",
    "description": "Cheat table for Napoleon Total War Steam version 1.6",
    "notes": "Pointer offsets may vary between game patches. Use AOB scanning for more stable addresses.",
    
    "pointer_chains": {
        "treasury": {
            "module": "napoleon.exe",
            "base_offset": "0x00A1B2C0",
            "offsets": ["0x4C", "0x10", "0x8"],
            "type": "int32",
            "description": "Player faction treasury (gold)"
        },
        "movement_points": {
            "module": "napoleon.exe",
            "base_offset": "0x00A1B2C0",
            "offsets": ["0x4C", "0x10", "0x14"],
            "type": "float",
            "description": "Selected army movement points"
        },
        "construction_timer": {
            "module": "napoleon.exe",
            "base_offset": "0x00A3D4E0",
            "offsets": ["0x28", "0x8", "0xC"],
            "type": "int32",
            "description": "Current building construction turns remaining"
        },
        "research_timer": {
            "module": "napoleon.exe",
            "base_offset": "0x00A3D4E0",
            "offsets": ["0x28", "0x10", "0xC"],
            "type": "int32",
            "description": "Current research turns remaining"
        }
    },
    
    "aob_patterns": {
        "treasury_write": {
            "pattern": "89 86 ?? ?? ?? ?? 8B 45 FC",
            "description": "Instruction that writes treasury value",
            "offset_from_match": 0,
            "nop_bytes": 6,
            "cheat_action": "NOP the write instruction to freeze treasury"
        },
        "movement_write": {
            "pattern": "F3 0F 11 86 ?? ?? ?? ?? F3 0F 10 45",
            "description": "Instruction that updates movement points",
            "offset_from_match": 0,
            "nop_bytes": 8
        },
        "health_write": {
            "pattern": "F3 0F 11 ?? ?? ?? ?? ?? 8B ?? ?? ?? ?? ?? 85",
            "description": "Instruction that modifies unit health",
            "offset_from_match": 0,
            "nop_bytes": 8
        },
        "ammo_decrement": {
            "pattern": "29 ?? ?? ?? ?? ?? 89 ?? ?? ?? ?? ?? 83",
            "description": "Instruction that decrements ammo count",
            "offset_from_match": 0,
            "nop_bytes": 6
        },
        "morale_write": {
            "pattern": "F3 0F 11 ?? ?? ?? ?? ?? F3 0F 10 ?? ?? ?? ?? ?? 0F 2F",
            "description": "Instruction that modifies unit morale",
            "offset_from_match": 0,
            "nop_bytes": 8
        }
    },
    
    "scan_guides": {
        "treasury": {
            "type": "int32",
            "steps": [
                "1. Note your current gold amount in the campaign UI",
                "2. Scan for that exact value (4 Bytes / int32)",
                "3. Spend some gold (recruit a unit, construct a building)",
                "4. Scan for the new (decreased) value",
                "5. Repeat steps 3-4 until 1-3 addresses remain",
                "6. Change value to desired amount (e.g., 999999)"
            ]
        },
        "unit_health": {
            "type": "float",
            "steps": [
                "1. Start a battle and select a unit",
                "2. Note the unit's health percentage",
                "3. Scan for that value as Float (e.g., 100.0 for full health)",
                "4. Let the unit take damage",
                "5. Scan for decreased value",
                "6. Repeat until address found",
                "7. Freeze at 100.0 for god mode"
            ]
        },
        "movement_points": {
            "type": "float",
            "steps": [
                "1. Select an army on the campaign map",
                "2. Scan for unknown value (Float)",
                "3. Move the army a short distance",
                "4. Scan for decreased value",
                "5. End turn (points reset)",
                "6. Scan for increased value",
                "7. Repeat until address found"
            ]
        }
    }
}
